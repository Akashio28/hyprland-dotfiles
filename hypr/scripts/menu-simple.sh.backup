        exit 0
        ;;
esac#!/bin/bash

CHOICE=$(echo -e "Restart\nShutdown\nLogout" | rofi -dmenu -p "Pilih:")

case $CHOICE in
    "Restart")
        systemctl reboot
        ;;
    "Shutdown")
        systemctl poweroff
        ;;
    "Logout")
        hyprctl dispatch exit
        ;;
    *)
        echo "Batal"
        ;;
esac
#!/bin/bash

# Tunggu sebentar agar keyboard grab berhasil
sleep 0.1

CHOICE=$(echo -e "Restart\nShutdown\nLogout" | rofi -dmenu -p "Pilih:" -lines 3 -width 20% -location 0 -yoffset 50)

case $CHOICE in
    "Restart")
        systemctl reboot
        ;;
    "Shutdown")
        systemctl poweroff
        ;;
    "Logout")
        hyprctl dispatch exit
        ;;
    *)
        echo "Batal"
        ;;
esac
#!/bin/bash

CHOICE=$(echo -e "Restart\nShutdown\nLogout" | rofi -dmenu \
  -p "Menu:" \
  -lines 3 \
  -width 15% \          # Lebih kecil, coba 15-25%
  -location 2 \         # 0=center, 1=north, 2=south, dll
  -yoffset -50 \        # Naikkan sedikit dari bawah
  -xoffset 0 \
  -theme-str 'window {border-radius: 8px; padding: 5px;} listview {lines: 3;}' \
  -theme-str 'element {padding: 4px 8px;}' \
  -theme-str 'element-text {font: "Inter 11";}')

case $CHOICE in
    "Restart")
        systemctl reboot
        ;;
    "Shutdown")
        systemctl poweroff
        ;;
    "Logout")
        hyprctl dispatch exit
        ;;
    *)
        exit 0
        ;;
esac
