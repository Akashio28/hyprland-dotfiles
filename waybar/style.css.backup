@import "colors.css";

* {
    margin: 0px;
    padding: 2px 2px;
    border: none;
    font-family: "JetBrains Nerd Font", "Helvetica Neue", Arial, sans-serif;
    font-size: 14px;
}

window#waybar {
    background-color: alpha(@surface_container_highest, 0.0);
    color: white;
}

/* Style untuk module label */
label.module {
    color: @primary;
    font-weight: bold;
    padding: 0px 10px;
}

/* Tooltip styling */
tooltip {
    background: rgba(43, 48, 59, 0.9);
    border: 1px solid rgba(100, 114, 125, 0.5);
    border-radius: 10px;
}
tooltip label {
    color: @on_secondary;
}

/* WORKSPACES SECTION */
#workspaces {
background: alpha(@background, 0.5);
color: @on_primary_fixed;
border-radius: 100px;
padding: 4px;
border: 1px solid @on_secondary;
margin: 4px;
}

#workspaces button {
padding: 0px 15px;
margin: 2px;
color: @on_surface;
border-radius: 100px;
transition: all 0.3s ease;
}

#workspaces button.focused {
padding: 4px;
margin: 2px;
background: @on_primary_container;
color: @on_primary_fixed;
border-radius: 100px;
}

#workspaces button.active {
padding: 0px 15px;
margin: 2px;
background: @color6;
color: @on_primary_fixed;
border-radius: 100px;
}

#workspaces button:hover {
color: @primary;
background: @on_primary_fixed_variant;
}

/* MODULE STYLING - General */
#clock,
#battery,
#pulseaudio,
#network,
#backlight,
#custom-swaync,
#tray,
#custom-temperature,
#custom-light,
#custom-nix,
#custom-bluetooth,
#cava,
#window {
color: @color7;
padding: 2px 15px;
margin: 2px;
border-radius: 50px;
background-color: alpha(@background, 0.5);
transition: all 0.2s ease;
}

/* Individual module borders */
#custom-bluetooth{
border: 1px solid @on_secondary;
}

#custom-nix{
border: 1px solid @on_secondary;
}
#clock {
border: 1px solid @on_secondary;
}

#battery {
border: 1px solid @on_secondary;
}

#custom-swaync {
border: 1px solid @on_secondary;
}

#tray {
border: 1px solid @on_secondary;
}

/* Temperature & Light combo styling */
#custom-temperature {
border-top-right-radius: 0;
border-bottom-right-radius: 0;
margin-right: 0px;
border-left: 1px solid @on_secondary;
border-top: 1px solid @on_secondary;
border-bottom: 1px solid @on_secondary;
}

#custom-light {
border-top-left-radius: 0;
border-bottom-left-radius: 0;
margin-left: 0px;
border-right: 1px solid @on_secondary;
border-top: 1px solid @on_secondary;
border-bottom: 1px solid @on_secondary;
}

/* Backlight & Pulseaudio combo styling */
#backlight {
border-top-right-radius: 0;
border-bottom-right-radius: 0;
margin-right: 0px;
border-left: 1px solid @on_secondary;
border-top: 1px solid @on_secondary;
border-bottom: 1px solid @on_secondary;
}

#pulseaudio {
border-top-left-radius: 0;
border-bottom-left-radius: 0;
margin-left: 0px;
border-right: 1px solid @on_secondary;
border-top: 1px solid @on_secondary;
border-bottom: 1px solid @on_secondary;
}

/* HOVER EFFECTS - Menggabungkan kedua style */
#clock:hover,
#battery:hover,
#pulseaudio:hover,
#network:hover,
#backlight:hover,
#custom-swaync:hover,
#tray:hover,
#custom-temperature:hover,
#custom-light:hover,
#custom-nix:hover,
#custom-bluetooth:hover,
#cava:hover,
#window:hover {
background: @primary;
color: @on_primary_fixed;
box-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
border-color: @primary; /* Border ikut berubah warna */
}

/* ACTIVE EFFECT (saat diklik) */
#clock:active,
#battery:active,
#pulseaudio:active,
#network:active,
#backlight:active,
#custom-swaync:active,
#custom-temperature:active,
#custom-light:active,
#custom-nix:active,
#custom-bluetooth:active,
#cava:active,
#window:active {
opacity: 0.7;
}

/* CAVA specific */
#cava {
color: @primary;
padding: 0px;
margin: 0px;
}

/* WINDOW specific */
#window {
color: white;
font-weight: bold;
}

/* Animation for blinking */
@keyframes blink {
    to {
        background-color: #ffffff;
        color: black;
    }
}

/* Tooltip untuk clock (dari file pertama) */
#clock.tooltip {
transition: opacity 0.3s ease;
opacity: 0;
}

#clock:hover .tooltip {
opacity: 1;
}
