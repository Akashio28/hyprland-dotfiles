#!/bin/bash
# ~/.config/hypr/scripts/wofi-power-menu.sh

# Theme untuk wofi
WOFI_STYLE=$(cat << EOF
#wofi {
    border-radius: 12px;
    border: 2px solid #cba6f7;
    background-color: #1e1e2e;
    color: #cdd6f4;
}
#entry {
    padding: 10px;
    border-radius: 8px;
}
#list {
    padding: 10px;
}
EOF
)

# Tampilan utama
MAIN_MENU() {
    echo -e "ÔúÖ  Shutdown\nÓęí  Restart\nůįćÉ  Logout\nůįĆĺ  Lock\nůįúļ  Suspend\nůįĖĒ  Cancel" | \
    wofi --dmenu \
        --prompt "‚öôÔłŹ  System Menu" \
        --width 280 \
        --height 250 \
        --location center \
        --hide-scroll \
        --style "$WOFI_STYLE" \
        --normal-window
}

# Tampilan konfirmasi
CONFIRM_MENU() {
    local action=$1
    echo -e "‚úÖ  Yes\n‚ĚĆ  No" | \
    wofi --dmenu \
        --prompt "‚ö†ÔłŹ  $action?" \
        --width 220 \
        --height 120 \
        --location center \
        --hide-scroll \
        --style "$WOFI_STYLE" \
        --normal-window
}

# ===== MAIN SCRIPT =====

# Tampilkan menu utama
CHOICE=$(MAIN_MENU)

# Proses pilihan
case $CHOICE in
    "ÔúÖ  Shutdown")
        CONFIRM=$(CONFIRM_MENU "Shutdown system")
        [ "$CONFIRM" = "‚úÖ  Yes" ] && systemctl poweroff
        ;;
    
    "Óęí  Restart")
        CONFIRM=$(CONFIRM_MENU "Restart system")
        [ "$CONFIRM" = "‚úÖ  Yes" ] && systemctl reboot
        ;;
    
    "ůįćÉ  Logout")
        CONFIRM=$(CONFIRM_MENU "Logout from session")
        [ "$CONFIRM" = "‚úÖ  Yes" ] && hyprctl dispatch exit
        ;;
    
    "ůįĆĺ  Lock")
        # Lock screen biasanya tidak perlu konfirmasi
        swaylock
        ;;
    
    "ůįúļ  Suspend")
        CONFIRM=$(CONFIRM_MENU "Suspend system")
        [ "$CONFIRM" = "‚úÖ  Yes" ] && systemctl suspend
        ;;
    
    *)
        # Cancel atau pilihan tidak dikenal
        exit 0
        ;;
esac#!/bin/bash
